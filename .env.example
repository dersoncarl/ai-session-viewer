# Copy this file to .env, then adjust the paths for your machine.

# Local session data.
SESSION_HOME=$HOME/.ai-sessions

# Preferred local port. If this port is busy, the app picks the next available port.
PORT=8787

# Session scan cache in milliseconds.
SESSION_CACHE_TTL_MS=5000

# Delete mode:
# archive = move session JSONL files to SESSION_HOME/session-trash (default)
# hard = permanently remove session JSONL files
DELETE_MODE=archive
